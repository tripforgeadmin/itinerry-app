flowchart TD
    Start(["เริ่ม · ยินยอม PDPA + รับทราบ"]) --> S1["S1 · สัญชาติ + ประเทศปลายทาง"]
    S1 --> Q9{"Q9 · ประเภทวีซ่า?"}

    %% ===== จุดแยกที่ 1: ประเภทวีซ่า =====
    Q9 -->|"ท่องเที่ยว Tourist"| TA["Q10–11 · วันเดินทาง + วันกลับ<br/>Q12 · เคยได้วีซ่า UK/US/Schengen ใน 5 ปี?"]
    Q9 -->|"เยี่ยมเยียน Visitor"| TB["Q13 · วันเดินทาง<br/>Q14 · สถานะคนที่ไปเยี่ยม<br/>Q15 · ความสัมพันธ์กับผู้เชิญ<br/>Q16 · เอกสารที่ผู้เชิญส่งได้"]
    Q9 -->|"ธุรกิจ Business"| TC["Q17–18 · วันเดินทาง + วันกลับ<br/>Q19 · หนังสือเชิญจากบริษัท?<br/>Q20 · เคยได้วีซ่าใน 5 ปี?"]
    Q9 -->|"นักเรียน Student"| TS["Q21 · วันเริ่มเรียน<br/>Q22 · Acceptance Letter?<br/>Q23 · ใครจ่ายค่าใช้จ่าย?"]

    %% ทุก branch วีซ่ามาบรรจบที่ Q24
    TA --> Q24
    TB --> Q24
    TC --> Q24
    TS --> Q24

    %% ===== จุดแยกที่ 2: อาชีพ =====
    Q24{"Q24 · อาชีพปัจจุบัน?"}
    Q24 -->|"พนักงาน / ข้าราชการ"| OA["Q25 · หนังสือรับรองงาน<br/>ตำแหน่ง + เงินเดือน + วันลา?"]
    Q24 -->|"Freelance"| OB["Q26 · เอกสารพิสูจน์รายได้?<br/>Q27 · เอกสารภาษีย้อนหลัง 3 ปี?"]
    Q24 -->|"เจ้าของธุรกิจ"| OC["Q28 · หนังสือรับรองบริษัท DBD?"]
    Q24 -->|"เกษียณ / แม่บ้าน / นักเรียน"| OD["Q29 · ใครรับผิดชอบค่าใช้จ่าย?"]

    %% ทุก branch อาชีพมาบรรจบที่ S5 (Q30)
    OA --> Q30
    OB --> Q30
    OC --> Q30
    OD --> Q30

    %% ===== S5 คัดกรองหลัก: มีเงื่อนไขย่อย =====
    Q30{"Q30 · เคยถูกปฏิเสธวีซ่า?"}
    Q30 -->|"เคย"| Q31["Q31 · ระบุประเทศ + ปี"]
    Q30 -->|"ไม่เคย"| Q32
    Q31 --> Q32

    Q32{"Q32 · เคย Overstay?"}
    Q32 -->|"เคย"| Q33["Q33 · ระบุประเทศ ระยะเวลา ปี"]
    Q32 -->|"ไม่เคย"| Q34
    Q33 --> Q34

    Q34["Q34 · ยอดเงินออม<br/>Q35 · ความผูกพันกับไทย"]
    Q34 --> LAST

    %% ===== ชุดสุดท้าย (ที่ย้ายมา) =====
    LAST["ชุดสุดท้าย · ชื่อ + เบอร์ + อีเมล<br/>รู้จักจากช่องไหน + รับรองข้อมูลจริง"]
    LAST --> Q36{"Q36 · ช่องทางติดต่อกลับ?"}

    %% ===== จุดแยกที่ 3: ช่องทางติดต่อ =====
    Q36 -->|"ให้โทรกลับ"| Q37["Q37 · ช่วงเวลาที่สะดวก"]
    Q36 -->|"Add LINE OA"| END
    Q37 --> END

    END(["ส่งแบบประเมิน → หน้า Confirmation"])

    %% ===== สไตล์ =====
    classDef decision fill:#FEF3C7,stroke:#D97706,stroke-width:2px,color:#1F2937
    classDef terminal fill:#DBEAFE,stroke:#2563EB,stroke-width:2px,color:#1F2937
    classDef sensitive fill:#FEE2E2,stroke:#DC2626,stroke-width:1.5px,color:#1F2937
    classDef branch fill:#F3F4F6,stroke:#6B7280,stroke-width:1px,color:#1F2937

    class Q9,Q24,Q30,Q32,Q36 decision
    class Start,END terminal
    class Q31,Q33 sensitive
    class TA,TB,TC,TS,OA,OB,OC,OD,Q34,LAST,S1 branch
